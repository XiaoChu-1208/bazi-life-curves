// v9.3.1 · 顶层 ErrorBoundary：任意 React 子树抛错都能落到可读的错误卡片，
// 而不是控制台报错 + 整页空白 #app（用户刷新无解）。
class ErrorBoundary extends React.Component {
  constructor(props) {
    super(props);
    this.state = { error: null, info: null };
  }
  static getDerivedStateFromError(error) {
    return { error };
  }
  componentDidCatch(error, info) {
    this.setState({ info });
    if (window.console) console.error("[bazi-artifact] render error:", error, info);
  }
  render() {
    if (this.state.error) {
      const msg = (this.state.error && this.state.error.message) || String(this.state.error);
      return (
        <div className="error-boundary" data-resilience-fallback="error-boundary"
             style={{
               margin: "32px auto", maxWidth: 720, padding: "24px",
               background: "#fef6f0", border: "1px solid #d9a384",
               borderRadius: 8, color: "#7a3a1f", fontSize: 14, lineHeight: 1.6,
             }}>
          <div style={{fontWeight: 700, fontSize: 16, marginBottom: 8}}>
            报告渲染失败
          </div>
          <div style={{marginBottom: 12}}>
            页面加载时遇到错误，常见原因：曲线数据不完整 / LLM 输出片段格式异常 / 浏览器与脚本不兼容。
          </div>
          <details style={{marginBottom: 12, fontSize: 12, color: "#9a4632"}}>
            <summary style={{cursor: "pointer"}}>查看错误详情（开发者用）</summary>
            <pre style={{
              marginTop: 8, padding: 10, background: "#fff", border: "1px solid #ebd0bf",
              borderRadius: 4, overflow: "auto", whiteSpace: "pre-wrap", wordBreak: "break-word",
            }}>{msg}</pre>
          </details>
          <div style={{fontSize: 12, color: "#9a6a4a"}}>
            建议：刷新页面；若多次失败，请把这段错误信息附在 issue 里反馈。
          </div>
        </div>
      );
    }
    return this.props.children;
  }
}

const {
