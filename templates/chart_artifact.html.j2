<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{{ title }}</title>
<script src="https://cdn.jsdelivr.net/npm/react@18.3.1/umd/react.production.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/react-dom@18.3.1/umd/react-dom.production.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/prop-types@15.8.1/prop-types.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/recharts@2.12.7/umd/Recharts.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/marked@13.0.2/marked.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@babel/standalone@7.24.7/babel.min.js"></script>
<style>
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", "Helvetica Neue", sans-serif;
    background: #fafaf7;
    color: #2c2c2c;
  }
  .root { padding: 24px; max-width: 1280px; margin: 0 auto; }
  h1 { font-size: 18px; font-weight: 600; margin: 0 0 4px; color: #1a1a1a; }
  .meta { color: #888; font-size: 13px; margin-bottom: 16px; }
  .meta b { color: #555; font-weight: 600; }

  /* --- 图表 --- */
  .chart-wrap { background: #fff; border-radius: 12px; padding: 20px 8px 12px; box-shadow: 0 1px 4px rgba(0,0,0,0.04); }
  .legend-row { display: flex; flex-wrap: wrap; gap: 16px 24px; padding: 0 16px 12px; font-size: 13px; }
  .legend-item { display: inline-flex; align-items: center; gap: 6px; }
  .legend-line { display: inline-block; width: 28px; height: 0; border-top: 2.6px solid; }
  .legend-line.dashed { border-top-style: dashed; border-top-width: 1.4px; opacity: 0.55; }
  .caveat { font-size: 12px; color: #999; margin-top: 8px; padding: 0 8px; }
  .mp-summary { margin-top: 6px; font-size: 11px; color: #888; padding: 0 8px; }

  /* --- 通用卡片 --- */
  .card {
    margin-top: 20px; background: #fff; border-radius: 12px;
    padding: 16px 20px; box-shadow: 0 1px 4px rgba(0,0,0,0.04);
  }
  .card > h2 { font-size: 15px; font-weight: 600; margin: 0 0 12px; color: #1a1a1a; }
  .card > .sub { font-size: 12px; color: #888; margin-bottom: 12px; }

  /* --- details 折叠 --- */
  details { padding: 4px 0; }
  details > summary {
    cursor: pointer; list-style: none; padding: 6px 0;
    font-size: 14px; font-weight: 600; color: #1a1a1a;
  }
  details > summary::-webkit-details-marker { display: none; }
  details > summary::before {
    content: "▸ "; display: inline-block; width: 16px;
    color: #999; transition: transform 0.15s;
  }
  details[open] > summary::before { transform: rotate(90deg); }

  /* --- 大运评价 --- */
  .dayun-list { display: flex; flex-direction: column; gap: 4px; }
  .dayun-item {
    border-bottom: 1px solid #f0f0ed;
    padding: 4px 0;
  }
  .dayun-item:last-child { border-bottom: none; }
  .dayun-item > summary {
    display: flex; align-items: center; gap: 12px;
    font-size: 13px; font-weight: 500;
  }
  .dayun-item .du-tag {
    display: inline-block; padding: 2px 8px; border-radius: 4px;
    font-size: 12px; font-weight: 600; color: #fff;
    min-width: 38px; text-align: center;
  }
  .dayun-item .du-range {
    color: #888; font-size: 12px; font-weight: normal;
  }
  .dayun-item .du-summary {
    color: #555; font-size: 12px; font-weight: normal; flex: 1;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .dayun-item .du-body { padding: 8px 0 12px 28px; }

  /* --- 关键年份评价 --- */
  .key-year {
    border-bottom: 1px solid #f0f0ed;
    padding: 6px 0;
  }
  .key-year:last-child { border-bottom: none; }
  .key-year > summary {
    display: flex; align-items: center; gap: 10px;
    font-size: 13px; font-weight: 500; flex-wrap: wrap;
  }
  .key-year .ky-year { font-weight: 600; color: #1a1a1a; min-width: 84px; }
  .key-year .ky-tag {
    display: inline-block; padding: 1px 7px; border-radius: 10px;
    font-size: 11px; line-height: 1.5;
  }
  .ky-tag.peak { background: #eaf4ee; color: #2c7a52; border: 1px solid #d3e8de; }
  .ky-tag.dip  { background: #fdf0e8; color: #b14a1a; border: 1px solid #f0d9c2; }
  .ky-tag.shift{ background: #f4f1fb; color: #5a4d8a; border: 1px solid #e2dcf2; }
  .key-year .ky-headline {
    color: #555; font-size: 12px; font-weight: normal;
    flex: 1; min-width: 200px;
  }
  .key-year .ky-body { padding: 8px 0 12px 24px; }

  /* --- 一生评价（三维度并列卡） --- */
  .life-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 14px; margin-top: 4px;
  }
  .life-cell {
    border: 1px solid #f0f0ed; border-radius: 10px;
    padding: 12px 14px;
  }
  .life-cell .lc-head {
    font-size: 13px; font-weight: 600; margin-bottom: 8px;
    display: flex; align-items: center; gap: 8px;
  }
  .life-cell .lc-dot {
    display: inline-block; width: 10px; height: 10px; border-radius: 50%;
  }
  .life-cell.spirit { background: #faf9fd; }
  .life-cell.spirit .lc-dot { background: #8B7BC7; }
  .life-cell.spirit .lc-head { color: #5a4d8a; }
  .life-cell.wealth { background: #f7fbf9; }
  .life-cell.wealth .lc-dot { background: #4A9D7F; }
  .life-cell.wealth .lc-head { color: #2c6f5a; }
  .life-cell.fame   { background: #fdf8f4; }
  .life-cell.fame   .lc-dot { background: #D88E5C; }
  .life-cell.fame   .lc-head { color: #9c5d2e; }
  .life-cell.emotion { background: #fbf6f8; }
  .life-cell.emotion .lc-dot { background: #C77FA0; }
  .life-cell.emotion .lc-head { color: #8a4a68; }

  /* --- 承认维度（德性暗线 / virtue narrative · v9 新增 · 不画曲线，独立成块） --- */
  .virtue-card {
    background: #fbf7f1; border: 1px solid #e8dcc4; border-radius: 12px;
    padding: 16px 20px; margin-top: 20px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.04);
  }
  .virtue-card > h2 {
    font-size: 15px; font-weight: 600; color: #6b5a3a;
    margin: 0 0 4px; display: flex; align-items: center; gap: 8px;
  }
  .virtue-card > h2::before {
    content: ""; display: inline-block; width: 10px; height: 10px;
    border-radius: 50%; background: #a89070;
  }
  .virtue-card .sub { color: #8a7a55; font-size: 12px; margin-bottom: 12px; }
  .virtue-card .virtue-section {
    border-top: 1px dashed #e2d6b8; padding: 10px 0;
  }
  .virtue-card .virtue-section:first-of-type { border-top: none; padding-top: 6px; }
  .virtue-card .virtue-section > summary {
    font-size: 13px; font-weight: 600; color: #5a4a26;
    cursor: pointer; padding: 4px 0;
    display: flex; align-items: center; gap: 8px;
  }
  .virtue-card .virtue-section > summary .vs-pos {
    display: inline-block; font-size: 10px; padding: 1px 6px; border-radius: 3px;
    background: #d4c896; color: #3a2c10; font-weight: 500;
  }
  .virtue-card .virtue-section > summary .vs-hint {
    color: #a89070; font-size: 11px; font-weight: normal; margin-left: auto;
  }
  .virtue-card .virtue-section .vs-body { padding: 6px 0 4px 4px; }
  .virtue-card .motif-table {
    margin: 6px 0 0; padding-left: 0; list-style: none;
    display: grid; grid-template-columns: 1fr; gap: 4px;
  }
  .virtue-card .motif-row {
    display: flex; align-items: baseline; gap: 8px;
    font-size: 12px; color: #5a4a26;
    padding: 3px 8px; background: rgba(212, 200, 150, 0.15); border-radius: 4px;
  }
  .virtue-card .motif-row .motif-id {
    font-family: ui-monospace, monospace; color: #8a6f3a; font-size: 11px;
    min-width: 60px;
  }
  .virtue-card .motif-row .motif-grav {
    font-size: 10px; padding: 1px 5px; border-radius: 3px;
    background: #a89070; color: #fff; min-width: 36px; text-align: center;
  }
  .virtue-card .motif-row .motif-grav.gentle { background: #c9b878; }
  .virtue-card .motif-row .motif-grav.medium { background: #a89070; }
  .virtue-card .motif-row .motif-grav.heavy  { background: #8b5a3c; }
  .virtue-card .convergence-years {
    margin: 6px 0 0; font-size: 12px; color: #5a4a26;
  }
  .virtue-card .convergence-years .y-tag {
    display: inline-block; padding: 2px 8px; margin: 2px 4px 2px 0;
    background: #a89070; color: #fff; border-radius: 3px;
    font-family: ui-monospace, monospace; font-size: 11px;
  }
  .virtue-card .virtue-disabled {
    padding: 10px 12px; background: #f6efde; border-radius: 6px;
    color: #8a7a55; font-size: 12px; line-height: 1.6;
    border-left: 3px solid #d4c896;
  }
  .virtue-card .virtue-disabled code {
    background: rgba(0,0,0,0.05); padding: 1px 5px; border-radius: 3px;
    font-size: 11px; color: #5a4a26;
  }

  /* --- markdown --- */
  .markdown { font-size: 13px; line-height: 1.7; color: #333; }
  .markdown h1, .markdown h2, .markdown h3 { margin: 14px 0 6px; color: #1a1a1a; }
  .markdown h1 { font-size: 16px; }
  .markdown h2 { font-size: 14px; }
  .markdown h3 { font-size: 13px; font-weight: 600; }
  .markdown p { margin: 6px 0; }
  .markdown ul, .markdown ol { margin: 6px 0; padding-left: 24px; }
  .markdown li { margin: 2px 0; }
  .markdown blockquote {
    margin: 8px 0; padding: 6px 12px; background: #f6f4ee;
    border-left: 3px solid #d4c896; color: #5a4a26; font-size: 12px;
  }
  .markdown code {
    background: #f0eee7; padding: 1px 5px; border-radius: 3px; font-size: 12px;
  }
  .markdown strong { color: #1a1a1a; }

  .placeholder {
    color: #b8b8b8; font-style: italic; font-size: 12px; padding: 6px 0;
  }

  /* --- 整图综合分析 --- */
  .overall-analysis {
    background: #fff; border-radius: 12px;
    padding: 16px 20px; box-shadow: 0 1px 4px rgba(0,0,0,0.04);
    margin-top: 20px;
  }
  .overall-analysis > summary {
    font-size: 15px; font-weight: 600; color: #1a1a1a;
    padding: 4px 0;
  }
  .overall-analysis .markdown { padding-top: 12px; }

  /* --- v7.5 时代-民俗志卡片 --- */
  .era-list { display: flex; flex-direction: column; gap: 8px; }
  .era-item {
    border: 1px solid #ece7da; border-radius: 8px;
    padding: 10px 14px; background: #fbf9f3;
  }
  .era-item > summary {
    display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap;
    font-size: 13px; font-weight: 600; color: #5a4a26;
  }
  .era-item .era-span {
    font-size: 12px; color: #8a6f3a; font-weight: 500;
  }
  .era-item .era-keywords {
    color: #8a8676; font-size: 11px; font-weight: normal;
    flex: 1; min-width: 200px; overflow: hidden;
    text-overflow: ellipsis; white-space: nowrap;
  }
  .era-item .era-tag {
    display: inline-block; font-size: 10px; padding: 1px 6px; border-radius: 3px;
    background: #d4c896; color: #3a2c10;
  }
  .era-item .era-body { padding: 8px 0 0 0; margin-top: 8px;
    border-top: 1px dashed #e2d9be; }
  .era-item .era-meta {
    font-size: 11px; color: #8a8676; margin-bottom: 6px; line-height: 1.5;
  }
  .era-item .era-meta b { color: #5a4a26; font-weight: 600; }
  .era-banner {
    font-size: 11px; color: #888; margin-bottom: 12px;
    padding: 6px 10px; background: #f6f4ee; border-radius: 4px;
    border-left: 3px solid #d4c896;
  }

  /* --- 盲派事件小标签 --- */
  .mp-events { padding: 8px 12px; background: #fffaf0; border: 1px dashed #d4c896; border-radius: 6px; margin-top: 8px; }
  .mp-events .head { font-size: 12px; color: #8b5a00; font-weight: 600; margin-bottom: 6px; }
  .mp-event-item { font-size: 12px; color: #5a4a26; margin: 4px 0; line-height: 1.5; }
  .mp-event-item .badge {
    display: inline-block; font-size: 10px; padding: 1px 6px; border-radius: 3px;
    background: #E8B947; color: #fff; margin-right: 6px;
  }
  .mp-event-item .badge.mid { background: #d4a847; }
  .mp-event-item .badge.light { background: #c9b878; }
</style>
</head>
<body>
<div id="app" class="root"></div>

<script>
window.__BAZI_CURVES__ = {{ curves_json|safe }};
window.__BAZI_TITLE__ = {{ title|tojson }};
window.__BAZI_ANALYSIS__ = {{ analysis_json|safe }};
window.__BAZI_ZEITGEIST__ = {{ zeitgeist_json|safe }};
window.__BAZI_HAS_ZEITGEIST__ = {{ "true" if has_zeitgeist else "false" }};
window.__BAZI_VIRTUE_MOTIFS__ = {{ virtue_motifs_json|safe }};
window.__BAZI_HAS_VIRTUE_MOTIFS__ = {{ "true" if has_virtue_motifs else "false" }};
window.__BAZI_PARTIAL__ = {{ "true" if allow_partial else "false" }};
</script>
{% raw %}
<script type="text/babel" data-presets="env,react">
const CURVES = window.__BAZI_CURVES__;
const TITLE = window.__BAZI_TITLE__;
const ANALYSIS = window.__BAZI_ANALYSIS__ || {};
const ZEITGEIST = window.__BAZI_ZEITGEIST__ || {};
const HAS_ZEITGEIST = !!window.__BAZI_HAS_ZEITGEIST__;
const VIRTUE_MOTIFS = window.__BAZI_VIRTUE_MOTIFS__ || null;
const HAS_VIRTUE_MOTIFS = !!window.__BAZI_HAS_VIRTUE_MOTIFS__;
const IS_PARTIAL = !!window.__BAZI_PARTIAL__;
const DIM_LABEL = { spirit: "精神", wealth: "财富", fame: "名声", emotion: "感情/关系" };

const COLOR_SPIRIT  = "#8B7BC7";
const COLOR_WEALTH  = "#4A9D7F";
const COLOR_FAME    = "#D88E5C";
const COLOR_EMOTION = "#C77FA0";

const DAYUN_BAND_COLORS = ["#F5F2EA", "#EDF2F4", "#F0E7E7", "#E7F0EE", "#F3EFE8", "#EFEDE6"];

function Markdown({ source }) {
  if (!source || !source.trim()) return null;
  const html = window.marked ? window.marked.parse(source) : source;
  return <div className="markdown" dangerouslySetInnerHTML={{ __html: html }} />;
}

const {
  ResponsiveContainer, ComposedChart, Line, XAxis, YAxis,
  CartesianGrid, ReferenceArea, ReferenceLine, Label, Tooltip,
} = Recharts;

/* === 5 年段趋势线：每 5 年取一段均值，对齐到段中心 === */
function buildSegmentTrend(yearly) {
  const SEG = 5;
  const out = [];
  for (let i = 0; i < yearly.length; i += SEG) {
    const slice = yearly.slice(i, Math.min(i + SEG, yearly.length));
    const ages  = slice.map(p => p.age);
    const center = (ages[0] + ages[ages.length - 1]) / 2;
    const mean = slice.reduce((s, p) => s + p.value, 0) / slice.length;
    out.push({ age: center, value: Math.round(mean * 10) / 10 });
  }
  return out;
}

function buildSeries(curves) {
  // 主线：每年一个点
  const main = curves.points.map(p => ({
    age: p.age, year: p.year, dayun: p.dayun,
    spirit:  p.spirit_yearly,
    wealth:  p.wealth_yearly,
    fame:    p.fame_yearly,
    emotion: p.emotion_yearly,
  }));
  // 5 年段趋势
  const spiritTrend  = buildSegmentTrend(curves.points.map(p => ({age: p.age, value: p.spirit_yearly})));
  const wealthTrend  = buildSegmentTrend(curves.points.map(p => ({age: p.age, value: p.wealth_yearly})));
  const fameTrend    = buildSegmentTrend(curves.points.map(p => ({age: p.age, value: p.fame_yearly})));
  const emotionTrend = buildSegmentTrend(
    curves.points
      .filter(p => p.emotion_yearly != null)
      .map(p => ({age: p.age, value: p.emotion_yearly}))
  );
  // 合并到主数据集（用 age 对齐，趋势数据点用单独字段）
  const trendByAge = {};
  spiritTrend.forEach(p  => { trendByAge[p.age] = trendByAge[p.age] || {}; trendByAge[p.age].spirit_t  = p.value; });
  wealthTrend.forEach(p  => { trendByAge[p.age] = trendByAge[p.age] || {}; trendByAge[p.age].wealth_t  = p.value; });
  fameTrend.forEach(p    => { trendByAge[p.age] = trendByAge[p.age] || {}; trendByAge[p.age].fame_t    = p.value; });
  emotionTrend.forEach(p => { trendByAge[p.age] = trendByAge[p.age] || {}; trendByAge[p.age].emotion_t = p.value; });

  // 把趋势点（可能是非整数年龄）作为单独序列返回，避免 Recharts 数值轴对不齐
  return {
    main,
    trend: { spirit: spiritTrend, wealth: wealthTrend, fame: fameTrend, emotion: emotionTrend },
  };
}

function MangpaiBlock({ events }) {
  if (!events || events.length === 0) return null;
  const intensityClass = (i) => ({ "重": "", "中": "mid", "轻": "light" }[i] || "");
  return (
    <div className="mp-events">
      <div className="head">盲派应事（不进 25% 融合权重，仅作应事断 + 烈度修正）</div>
      {events.map((e, i) => (
        <div className="mp-event-item" key={i}>
          <span className={"badge " + intensityClass(e.intensity)}>{e.intensity}</span>
          <b>{e.name}</b>（{e.school}）：{e.canonical_event}
          <div style={{ color: "#888", fontSize: 11, marginTop: 2, paddingLeft: 8 }}>
            触发：{e.evidence}
          </div>
          <div style={{ color: "#a08758", fontSize: 11, marginTop: 2, paddingLeft: 8, fontStyle: "italic" }}>
            可证伪：{e.falsifiability}
          </div>
        </div>
      ))}
    </div>
  );
}

function App() {
  const series = buildSeries(CURVES);
  const data = series.main;
  const ages = data.map(d => d.age);
  const minAge = Math.min(...ages);
  const maxAge = Math.max(...ages);
  const segments = CURVES.dayun_segments || [];

  // 把 5 年段趋势数据 inline 到 data（用 null 填空）
  const trendByAge = { spirit: {}, wealth: {}, fame: {}, emotion: {} };
  ["spirit", "wealth", "fame", "emotion"].forEach(k => {
    series.trend[k].forEach(p => { trendByAge[k][p.age] = p.value; });
  });
  // 给 data 补 _t 字段（在主点上不一定有匹配，所以另用一个稀疏轴）
  // 处理半整数年龄：扩展 data 包含趋势中点
  const allAges = new Set(ages);
  ["spirit", "wealth", "fame", "emotion"].forEach(k =>
    series.trend[k].forEach(p => allAges.add(p.age))
  );
  const sortedAges = Array.from(allAges).sort((a, b) => a - b);
  const yearMap = {};
  data.forEach(d => { yearMap[d.age] = d; });

  const merged = sortedAges.map(a => {
    const base = yearMap[a] || { age: a, year: null };
    return {
      ...base,
      spirit_t:  trendByAge.spirit[a]  != null ? trendByAge.spirit[a]  : null,
      wealth_t:  trendByAge.wealth[a]  != null ? trendByAge.wealth[a]  : null,
      fame_t:    trendByAge.fame[a]    != null ? trendByAge.fame[a]    : null,
      emotion_t: trendByAge.emotion[a] != null ? trendByAge.emotion[a] : null,
    };
  });

  const pointsByYear = {};
  const pointsByAge = {};
  (CURVES.points || []).forEach(p => { pointsByYear[p.year] = p; pointsByAge[p.age] = p; });

  // === Tooltip 组件（rich hover）===
  const keyYearByYear = {};
  (ANALYSIS.key_years || []).forEach(k => { keyYearByYear[k.year] = k; });

  const RichTooltip = ({ active, payload, label }) => {
    if (!active || !payload || payload.length === 0) return null;
    const age = label;
    const p = pointsByAge[age];
    if (!p) {
      // 趋势中点（无原始 point），简化显示
      return (
        <div style={{
          background: "rgba(255,255,255,0.96)", border: "1px solid #ddd",
          borderRadius: 6, padding: "8px 12px", fontSize: 12, color: "#444",
          boxShadow: "0 2px 8px rgba(0,0,0,0.08)", maxWidth: 280
        }}>
          <div style={{fontWeight: 600, marginBottom: 4}}>{age} 岁（趋势中点）</div>
          {payload.filter(e => e.value != null).map(e => (
            <div key={e.dataKey} style={{display: "flex", justifyContent: "space-between", gap: 12}}>
              <span style={{color: e.color}}>{
                {spirit:"精神", wealth:"财富", fame:"名声", emotion:"感情/关系",
                 spirit_t:"精神·5年趋势", wealth_t:"财富·5年趋势", fame_t:"名声·5年趋势",
                 emotion_t:"感情·5年趋势"}[e.dataKey] || e.dataKey
              }</span>
              <b>{e.value.toFixed(1)}</b>
            </div>
          ))}
        </div>
      );
    }
    const ky = keyYearByYear[p.year];
    const mpEvents = (p.mangpai_events || []).filter(e => e.name);
    const interactions = (p.interactions || []);
    return (
      <div style={{
