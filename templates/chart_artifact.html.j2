          <div style={{
            marginTop: 8, padding: "6px 8px",
            background: ky.kind === "peak" ? "#eaf5ec" : ky.kind === "dip" ? "#fbeae5" : "#eef0f7",
            borderRadius: 4, fontSize: 11, color: "#444"
          }}>
            <b style={{color: ky.kind === "peak" ? "#3d7a47" : ky.kind === "dip" ? "#9a4632" : "#4a5a85"}}>
              {ky.kind === "peak" ? "★ 关键高峰" : ky.kind === "dip" ? "★ 关键低谷" : "★ 关键拐点"}：
            </b>
            {ky.headline}
            <div style={{marginTop: 3, fontSize: 10, color: "#888"}}>
              点击下方"关键年份评价"区段查看完整解析
            </div>
          </div>
        )}
      </div>
    );
  };

  const mpYearsCount = (CURVES.points || []).filter(p => (p.mangpai_events || []).length > 0).length;
  const mpHighCount = (CURVES.points || []).reduce((acc, p) =>
    acc + (p.mangpai_events || []).filter(e => e.intensity === "重").length, 0);

  // 大运颜色 chip
  const dayunColor = (i) => {
    const palette = ["#7B9FCB", "#88B98C", "#D88E5C", "#A57AC9", "#D9A03F", "#5BA9A0"];
    return palette[i % palette.length];
  };

  // 每个大运段对应的年份范围（用于 LLM analysis.dayun_review 索引）
  const dayunReview = ANALYSIS.dayun_review || {};
  // v7.5 新增：dayun_reviews（按 dayun_label → markdown，整体替代 dayun_review.body 的扩展版）
  const dayunReviews = ANALYSIS.dayun_reviews || {};
  const keyYears = ANALYSIS.key_years || [];   // [{year, age, ganzhi, dayun, kind: 'peak'|'dip'|'shift', headline, body}]
  const lifeReview = ANALYSIS.life_review || {}; // {spirit, wealth, fame, emotion}
  const virtueNarrative = ANALYSIS.virtue_narrative || {}; // {opening, declaration, love_letter, free_speech, convergence_notes}
  // v9.4 motif_witness 独立母题侧记节点（fate master 第三人称累加旁白）
  // {after_current_dayun, after_current_liunian, after_dayun.<label>, after_key_years, before_closing}
  const motifWitness = ANALYSIS.motif_witness || {};

  // v7.5 时代-民俗志：era_windows_used（来自 _zeitgeist_loader）+ era_narratives（LLM 写）
  const eraWindows = (ZEITGEIST.era_windows_used || []);
  const eraNarratives = ANALYSIS.era_narratives || {};
  const dayunSegByYear = (yr) => segments.find(s => s.start_year <= yr && yr <= s.end_year);

  // v9 当前大运快照：bazi.json 里有 current_dayun_label 时显示
  const currentDayun = CURVES.current_dayun_label || (CURVES.bazi && CURVES.bazi.current_dayun_label) || "";
  const currentDayunRange = CURVES.current_dayun_year_range || (CURVES.bazi && CURVES.bazi.current_dayun_year_range) || "";
  const currentDayunAge = CURVES.current_dayun_age_range || (CURVES.bazi && CURVES.bazi.current_dayun_age_range) || "";
  const currentDayunBody = currentDayun ? (dayunReviews[currentDayun] || "") : "";

  // v9 盲派 / 子平正格 冲突警示：phase_decision.mangpai_conflict_alert
  const phaseDecision = (CURVES.bazi && CURVES.bazi.phase_decision) || CURVES.phase_decision || {};
  const mangpaiAlert = phaseDecision.mangpai_conflict_alert || null;

  // v9.4 算法判断披露：永远渲染（"用户没办法判断你算没算" 的根治）
  // 数据来自 score_curves.py 写到 curves.json 的 phase / phase_decision / phase_confirmation
  const phaseSummary = CURVES.phase || {};
  const phaseConfirmation =
    (CURVES.bazi && CURVES.bazi.phase_confirmation) || CURVES.phase_confirmation || null;
  const multiVote = CURVES.multi_school_vote || null;
  const pdLabel = phaseSummary.label || phaseDecision.phase_label || "（未确定）";
  const pdId = phaseSummary.id || phaseDecision.decision || "unknown";
  const pdConfidence = phaseSummary.confidence || phaseDecision.confidence || "unknown";
  const pdProb = (() => {
    const v = phaseSummary.decision_probability ?? phaseDecision.decision_probability;
    return Number.isFinite(Number(v)) ? Number(v) : null;
  })();
  const pdProvisional = phaseSummary.is_provisional === true || phaseDecision.is_provisional === true;
  const pdInverted = phaseSummary.is_inverted === true;
  const confirmationAction = phaseConfirmation?.action || null; // render / render_with_caveat / escalate
  const confirmationStatus = phaseConfirmation?.status || null; // confirmed / weakly_confirmed / decision_changed / uncertain
  const needsRecheck =
    pdProvisional ||
    pdConfidence === "low" ||
    pdConfidence === "reject" ||
    confirmationAction === "escalate" ||
    confirmationStatus === "decision_changed" ||
    confirmationStatus === "uncertain";
  // 后验 top-3 候选（不含主决策）— 让用户看到"还有哪些读法被系统认真考虑过"
  const posteriorRunners = (() => {
    const dist = phaseDecision.posterior_distribution || {};
    const decision = phaseDecision.decision || phaseSummary.id;
    const entries = Object.entries(dist)
      .filter(([k]) => k !== decision)
      .map(([k, v]) => [k, Number(v) || 0])
      .sort((a, b) => b[1] - a[1])
      .slice(0, 3)
      .filter(([, v]) => v >= 0.02);
    return entries;
  })();

  return (
    <>
      <PartialBanner />
      <CoverageBanner />
      <h1>{TITLE}</h1>
      <div className="meta">
        {/* v9.3.1 · resilience: 全部嵌套访问改可选链 + 兜底，缺字段不再白屏 */}
        日主 <b>{CURVES.day_master || "—"}</b>
        （{(CURVES.strength && CURVES.strength.label) || "—"}）
        {(CURVES.yongshen && CURVES.yongshen.yongshen) ? <> · 用神 <b>{CURVES.yongshen.yongshen}</b></> : null}
        {(CURVES.yongshen && CURVES.yongshen.tongguan) ? ` · 通关 ${CURVES.yongshen.tongguan}` : ""}
        {(CURVES.yongshen && CURVES.yongshen.season) ? ` · 调候 ${CURVES.yongshen.season}` : ""}
        {CURVES.birth_year ? ` · 出生 ${CURVES.birth_year}` : ""}
      </div>

      {/* === v9.4 算法判断披露卡（永远渲染：命格 + 置信度 + 是否需要复核） === */}
      <div className={"phase-disclosure conf-" + pdConfidence}>
        <div className="pd-head">
          <span className="pd-tag">算法判断</span>
          <span className="pd-label">{pdLabel}</span>
          <span className="pd-id">{pdId}</span>
          {pdInverted && <span className="pd-id">· 反相位</span>}
        </div>
        <div className="pd-grid">
          <div>
            置信度：<b>{pdConfidence}</b>
            {pdProb !== null && <span className="pd-muted"> · P={pdProb.toFixed(3)}</span>}
          </div>
          <div>
            是否需要复核：
            <b>{needsRecheck ? "需要" : "否"}</b>
            {pdProvisional && <span className="pd-muted"> · 仅先验</span>}
          </div>
          {confirmationStatus && (
            <div>
              R2 校验状态：<b>{confirmationStatus}</b>
              {phaseConfirmation?.n_r1_answers != null && (
                <span className="pd-muted"> · R1 {phaseConfirmation.n_r1_answers} 题</span>
              )}
              {phaseConfirmation?.n_r2_answers != null && (
                <span className="pd-muted"> · R2 {phaseConfirmation.n_r2_answers} 题</span>
              )}
            </div>
          )}
          {multiVote && multiVote.consensus_level && (
            <div>
              多派共识：<b>{multiVote.consensus_level}</b>
              {multiVote.decision && (
                <span className="pd-muted"> · {String(multiVote.decision)}</span>
              )}
            </div>
          )}
        </div>
        {confirmationAction && (
          <div className={"pd-action act-" + confirmationAction}>
            渲染建议：<b>{confirmationAction}</b>
            {phaseConfirmation?.message && <> · {phaseConfirmation.message}</>}
          </div>
        )}
        {pdProvisional && (
          <div className="pd-provisional">
            ⚠ 当前判断仅基于先验（未经过 R1/R2 用户应答校验）。
            进入正式解读前应当先跑 elicit 流程把 is_provisional 翻成 false。
          </div>
        )}
        {!confirmationAction && !pdProvisional && needsRecheck && (
          <div className="pd-action act-render_with_caveat">
            建议复核：置信度偏低，可在重要决策前再跑一轮 R2 题集做交叉验证。
          </div>
        )}
        {posteriorRunners.length > 0 && (
          <div className="pd-runners">
            其他被认真考虑过的读法：
            {posteriorRunners.map(([k, v], i) => (
              <span key={"pr-"+i}>
                {i > 0 ? "、" : " "}<code>{k}</code> {(v * 100).toFixed(1)}%
              </span>
            ))}
          </div>
        )}
      </div>

      {/* === v9 盲派 / 子平正格冲突警示卡 === */}
      {mangpaiAlert && (
        <div className={"mangpai-conflict-alert sev-" + (mangpaiAlert.severity || "low")}>
          <div className="mca-title">
            <span className="mca-tag">
              {mangpaiAlert.severity === "high" ? "盲派强冲突 · 必读" :
               mangpaiAlert.severity === "mid"  ? "盲派冲突" : "盲派提示"}
            </span>
            算法决策：<b>{mangpaiAlert.decision_phase}</b>（{mangpaiAlert.decision_confidence}）
          </div>
          <div className="mca-decision">
            另有 {(mangpaiAlert.n_mangpai_high || 0)} 条盲派系
            {(mangpaiAlert.n_ziping_zhenge_high || 0) > 0
              ? ` + ${mangpaiAlert.n_ziping_zhenge_high} 条子平正格` : ""}
            （conf ≥ 0.80）指向另一相位；下列 hits 必须在叙事中被显式承认：
          </div>
          <ul className="mca-hits">
            {(mangpaiAlert.conflicting_hits || []).map((h, i) => (
              <li key={"mca-"+i}>
                {/* v9.3.1 · conf 可能是 null/undefined/string, 用 Number.isFinite 守卫防 NaN */}
                <b>{h.name_cn || h.id}</b>（conf={Number.isFinite(Number(h.confidence)) ? Number(h.confidence).toFixed(2) : "—"}）
                <span className="mca-hit-school">{h.school}</span>
              </li>
            ))}
          </ul>
          {mangpaiAlert.advisory && (
            <div className="mca-advisory">{mangpaiAlert.advisory}</div>
          )}
        </div>
      )}

      {/* === v9 当前大运快照（位置①开篇 + 当前大运段评价）=== */}
      {currentDayun && (
        <div className="current-dayun-snapshot">
          <div className="cds-title">
            <span className="cds-tag">当前大运</span>
            {currentDayun}
            {currentDayunAge ? <span className="cds-meta">  · {currentDayunAge}</span> : null}
            {currentDayunRange ? <span className="cds-meta">  · {currentDayunRange}</span> : null}
          </div>
          {virtueNarrative.opening && virtueNarrative.opening.trim() && (
            <div className="cds-opening"><Markdown source={virtueNarrative.opening} /></div>
          )}
          {currentDayunBody && currentDayunBody.trim() ? (
            <div className="cds-opening"><Markdown source={currentDayunBody} /></div>
          ) : (
            <div className="placeholder">
              当前大运段评价及十年逐年流年尚未写入。{IS_PARTIAL ? "⌛ 流式写作中。" : ""}
            </div>
          )}
        </div>
      )}

      {/* === 主图 === */}
      {!hasChartData && <NoChartFallback />}
      {hasChartData && (
      <div className="chart-wrap">
        <div className="legend-row">
          <span className="legend-item"><span className="legend-line" style={{borderTopColor: COLOR_SPIRIT}}></span>精神 · 当年</span>
          <span className="legend-item"><span className="legend-line dashed" style={{borderTopColor: COLOR_SPIRIT}}></span>精神 · 5 年趋势</span>
          <span className="legend-item"><span className="legend-line" style={{borderTopColor: COLOR_WEALTH}}></span>财富 · 当年</span>
          <span className="legend-item"><span className="legend-line dashed" style={{borderTopColor: COLOR_WEALTH}}></span>财富 · 5 年趋势</span>
          <span className="legend-item"><span className="legend-line" style={{borderTopColor: COLOR_FAME}}></span>名声 · 当年</span>
          <span className="legend-item"><span className="legend-line dashed" style={{borderTopColor: COLOR_FAME}}></span>名声 · 5 年趋势</span>
          <span className="legend-item"><span className="legend-line" style={{borderTopColor: COLOR_EMOTION}}></span>感情/关系 · 当年</span>
          <span className="legend-item"><span className="legend-line dashed" style={{borderTopColor: COLOR_EMOTION}}></span>感情/关系 · 5 年趋势</span>
        </div>

        <ResponsiveContainer width="100%" height={520}>
          <ComposedChart data={merged} margin={{top: 30, right: 30, left: 10, bottom: 10}}>
            {segments.map((seg, i) => (
              <ReferenceArea
                key={"seg-"+i}
                x1={seg.start_age} x2={seg.end_age}
                fill={DAYUN_BAND_COLORS[i % DAYUN_BAND_COLORS.length]}
                fillOpacity={0.45}
                ifOverflow="extendDomain"
                isFront={false}
              >
                <Label value={`${seg.label} (${seg.start_age}-${seg.end_age}岁)`}
                       position="insideTop" fill="#888" fontSize={11} />
              </ReferenceArea>
            ))}

            <CartesianGrid stroke="#eee" strokeDasharray="3 3" />
            <XAxis dataKey="age" type="number" domain={[minAge, maxAge]}
                   tickFormatter={(v) => v + "岁"} tick={{fontSize: 11, fill: "#666"}} />
            <YAxis domain={[10, 90]} tick={{fontSize: 11, fill: "#666"}} />
            {/* 基线 50 */}
            <ReferenceLine y={50} stroke="#ccc" strokeDasharray="2 4" />

            {/* === 关键年份竖线标记（peak/dip/shift） === */}
            {keyYears.map((k, i) => (
              <ReferenceLine key={"ky-"+i}
                x={k.age}
                stroke={k.kind === "peak" ? "#3d7a47" : k.kind === "dip" ? "#9a4632" : "#5a6a99"}
                strokeDasharray="3 3" strokeOpacity={0.55} strokeWidth={1}>
                <Label value={k.kind === "peak" ? "▲" : k.kind === "dip" ? "▼" : "◆"}
                       position="top"
                       fill={k.kind === "peak" ? "#3d7a47" : k.kind === "dip" ? "#9a4632" : "#5a6a99"}
                       fontSize={11} offset={4} />
              </ReferenceLine>
            ))}

            {/* === Hover Tooltip（年份 + 干支 + 大运 + 三维数 + 互动 + 盲派 + 关键年提示） === */}
            <Tooltip content={<RichTooltip />} cursor={{stroke: "#bbb", strokeWidth: 1, strokeDasharray: "4 4"}} />

            {/* === 5 年段趋势线（细虚线，背景） === */}
            <Line type="monotone" dataKey="spirit_t" stroke={COLOR_SPIRIT}
                  strokeWidth={1.5} strokeDasharray="5 4" strokeOpacity={0.55}
                  dot={{ r: 2.5, fill: COLOR_SPIRIT, strokeOpacity: 0 }}
                  connectNulls={true} isAnimationActive={false} />
            <Line type="monotone" dataKey="wealth_t" stroke={COLOR_WEALTH}
                  strokeWidth={1.5} strokeDasharray="5 4" strokeOpacity={0.55}
                  dot={{ r: 2.5, fill: COLOR_WEALTH, strokeOpacity: 0 }}
                  connectNulls={true} isAnimationActive={false} />
            <Line type="monotone" dataKey="fame_t"   stroke={COLOR_FAME}
                  strokeWidth={1.5} strokeDasharray="5 4" strokeOpacity={0.55}
                  dot={{ r: 2.5, fill: COLOR_FAME, strokeOpacity: 0 }}
                  connectNulls={true} isAnimationActive={false} />
            <Line type="monotone" dataKey="emotion_t" stroke={COLOR_EMOTION}
                  strokeWidth={1.5} strokeDasharray="5 4" strokeOpacity={0.55}
                  dot={{ r: 2.5, fill: COLOR_EMOTION, strokeOpacity: 0 }}
                  connectNulls={true} isAnimationActive={false} />

            {/* === 当年值（粗实线 + 圆点，主角） === */}
            <Line type="monotone" dataKey="spirit" stroke={COLOR_SPIRIT}
                  strokeWidth={2.6}
                  dot={{ r: 2.8, fill: COLOR_SPIRIT, stroke: "#fff", strokeWidth: 1 }}
                  connectNulls={true} isAnimationActive={false} />
            <Line type="monotone" dataKey="wealth" stroke={COLOR_WEALTH}
                  strokeWidth={2.6}
                  dot={{ r: 2.8, fill: COLOR_WEALTH, stroke: "#fff", strokeWidth: 1 }}
                  connectNulls={true} isAnimationActive={false} />
            <Line type="monotone" dataKey="fame"   stroke={COLOR_FAME}
                  strokeWidth={2.6}
                  dot={{ r: 2.8, fill: COLOR_FAME, stroke: "#fff", strokeWidth: 1 }}
                  connectNulls={true} isAnimationActive={false} />
            <Line type="monotone" dataKey="emotion" stroke={COLOR_EMOTION}
                  strokeWidth={2.6}
                  dot={{ r: 2.8, fill: COLOR_EMOTION, stroke: "#fff", strokeWidth: 1 }}
                  connectNulls={true} isAnimationActive={false} />
          </ComposedChart>
        </ResponsiveContainer>

        <div className="caveat">
          <b>粗实线＝当年值</b>（看具体年的尖峰谷底）　|　
          <b>淡虚线＝5 年段趋势</b>（每 5 年一段均值，描绘大运整体走势）　|　
          基线 50（虚横线）：&gt;50 为该年偏吉，&lt;50 偏凶。
        </div>
        {CURVES.mangpai_enabled && (
          <div className="mp-summary">
            盲派启用：{mpYearsCount} 年触发盲派经典组合（其中 {mpHighCount} 条「重」烈度），不进 25% 融合权重，仅做 ±烈度档修正。
          </div>
        )}
      </div>
      )}

      {/* === P5: 历次校验记忆（仅在有 confirmed_facts 时显示） === */}
      {ANALYSIS.confirmed_facts && Object.keys(ANALYSIS.confirmed_facts || {}).length > 0 && (
        <details className="confirmed-facts">
          <summary>
            <b style={{color:"#5a6a85"}}>历次校验记忆</b>
            <span style={{color:"#888", fontSize:11, marginLeft:8}}>
              （上次跑同一八字时用户已确认 / 已纠正的事实，本次解读不再重复踩坑）
            </span>
          </summary>
          <div style={{padding:"8px 12px", fontSize:12, lineHeight:1.7}}>
            {(ANALYSIS.confirmed_facts.structural_corrections || []).length > 0 && (
              <div style={{marginBottom:8}}>
                <b style={{color:"#9a4632"}}>结构性纠错：</b>
                <ul style={{margin:"4px 0 0 0", paddingLeft:18}}>
                  {ANALYSIS.confirmed_facts.structural_corrections.map((s, i) => (
                    <li key={i}>
                      <b>{s.kind}</b>: {s.before} → {s.after}
                      <span style={{color:"#888"}}> · {s.reason}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
            {(ANALYSIS.confirmed_facts.validations || []).length > 0 && (
              <div style={{marginBottom:8}}>
                <b style={{color:"#3a5378"}}>校验反馈（{ANALYSIS.confirmed_facts.validations.length} 条）：</b>
                <ul style={{margin:"4px 0 0 0", paddingLeft:18}}>
                  {ANALYSIS.confirmed_facts.validations.map((v, i) => (
                    <li key={i}>
                      [{v.round}] <b>{v.user_response === "对" ? "✓" : v.user_response === "不对" ? "✗" : "△"}</b>
                      {" "}{v.trait_or_anchor}
                      {v.user_note && <span style={{color:"#666"}}> — {v.user_note}</span>}
                    </li>
                  ))}
                </ul>
              </div>
            )}
            {(ANALYSIS.confirmed_facts.free_facts || []).length > 0 && (
              <div>
                <b style={{color:"#3d7a47"}}>已确认事实：</b>
                <ul style={{margin:"4px 0 0 0", paddingLeft:18}}>
                  {ANALYSIS.confirmed_facts.free_facts.map((f, i) => (
                    <li key={i}>{f.fact} <span style={{color:"#aaa", fontSize:10}}>({f.added})</span></li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </details>
      )}

      {/* === 整图综合分析（默认展开） === */}
      {/* v9.3.1 placeholder 文案剥离工程协议路径 (engineering 注释见 Jinja 注释块) */}
      <details className="overall-analysis" open>
        <summary>整图综合分析（命局基本盘 + 三条曲线形状 + 命主定位）</summary>
        {ANALYSIS.overall && ANALYSIS.overall.trim() ? (
          <Markdown source={ANALYSIS.overall} />
        ) : (
          <div className="placeholder">
            综合分析尚未写入。{IS_PARTIAL ? "⌛ 流式写作中，稍后会补齐这一节。" : "请稍后再读这一节。"}
          </div>
        )}
      </details>

      {/* === 一生四维度评价 === */}
      <div className="card">
        <h2>一生总评（四维度）</h2>
        <div className="sub">四条曲线的整体走势 / 长板短板 / 各维度的人生策略建议</div>
        <div className="life-grid">
          {[
            { key: "spirit",  name: "精神舒畅度" },
            { key: "wealth",  name: "财富" },
            { key: "fame",    name: "名声" },
            { key: "emotion", name: "感情/关系" },
          ].map(d => (
            <div key={d.key} className={"life-cell "+d.key}>
              <div className="lc-head"><span className="lc-dot"></span>{d.name}</div>
              {lifeReview[d.key] && lifeReview[d.key].trim() ? (
                <Markdown source={lifeReview[d.key]} />
              ) : (
                <div className="placeholder">
                  尚未写入「{d.name}」的一生总评。{IS_PARTIAL ? "⌛ 流式写作中。" : ""}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>

      {/* === 「我想和你说的话」（德性暗线 / virtue narrative · v9.3 改名 · 不画曲线，独立成块） === */}
      <div className="virtue-card">
        <h2>「我想和你说的话」（德性暗线 / virtue narrative）</h2>
        <div className="sub">
          这条独立叙事通道不进 25% 融合权重、不画曲线，结尾分三段：「我想和你说 / 项目的编写者想和你说 / 我（大模型）想和你说」。
          按 <code style={{fontSize:11}}>references/virtue_recurrence_protocol.md</code> 的 6 个写作位置由 LLM 流式累积写入。
        </div>

        {!HAS_VIRTUE_MOTIFS && (
          <div className="virtue-disabled">
            ⚠ <b>德性暗线未启用</b>：本次渲染未传入 <code>--virtue-motifs</code>（或 <code>output/*.virtue_motifs.json</code> 不存在）。
            请先跑 <code>python scripts/virtue_motifs.py --bazi output/X.bazi.json --curves output/X.curves.json --out output/X.virtue_motifs.json</code>，
            再用 <code>--virtue-motifs output/X.virtue_motifs.json</code> 重渲染。
            脚本侧的 38 条母题骨架是 LLM 写位置 ①③④⑤⑥ 的依据，缺了它德性暗线就只有空话。
          </div>
        )}

        {HAS_VIRTUE_MOTIFS && (() => {
          const triggered = (VIRTUE_MOTIFS && VIRTUE_MOTIFS.triggered_motifs) || [];
          const convergence = (VIRTUE_MOTIFS && VIRTUE_MOTIFS.convergence_years) || [];
          const blessing = !!(VIRTUE_MOTIFS && VIRTUE_MOTIFS.blessing_path);
          const loveOK = !!(VIRTUE_MOTIFS && VIRTUE_MOTIFS.love_letter_eligible);
          const hint = (VIRTUE_MOTIFS && VIRTUE_MOTIFS.convergence_hint) || "";
          return (
            <>
              <details className="virtue-section" open>
                <summary>
                  <span className="vs-pos">位置①</span>
                  <span>开篇悬疑提示（life_review 起笔即出现）</span>
                  <span className="vs-hint">analysis.virtue_narrative.opening</span>
                </summary>
                <div className="vs-body">
                  {virtueNarrative.opening && virtueNarrative.opening.trim() ? (
                    <Markdown source={virtueNarrative.opening} />
                  ) : (
                    <div className="placeholder">
                      开篇悬疑提示尚未写入。{IS_PARTIAL ? "⌛ 流式写作中。" : ""}
                    </div>
                  )}
                </div>
              </details>

              <details className="virtue-section" open>
                <summary>
                  <span className="vs-pos">骨架</span>
                  <span>母题清单 + 汇聚年表（脚本侧）</span>
                  <span className="vs-hint">virtue_motifs.json</span>
                </summary>
                <div className="vs-body">
                  <div style={{fontSize:12, color:"#5a4a26", marginBottom:6}}>
                    {blessing && <span style={{
                      display:"inline-block", padding:"2px 8px", marginRight:6,
                      background:"#e8f3e8", color:"#3d7a47", borderRadius:3, fontSize:11
                    }}>命好路径（blessing_path）</span>}
                    {loveOK && <span style={{
                      display:"inline-block", padding:"2px 8px", marginRight:6,
                      background:"#fbeaef", color:"#a8497a", borderRadius:3, fontSize:11
                    }}>「项目的编写者想和你说」条件成立（位置⑤可写）</span>}
                    {hint && <span style={{color:"#8a7a55", fontSize:11}}>{hint}</span>}
                  </div>
                  {triggered.length === 0 ? (
                    <div className="placeholder">（无母题触发 · 命主可能是清淡命，或 detector 暂未覆盖）</div>
                  ) : (
                    <ul className="motif-table">
                      {triggered.map((m, i) => (
                        <li key={i} className="motif-row">
                          <span className="motif-id">{m.id || "?"}</span>
                          <span className={"motif-grav "+(m.gravity || "gentle")}>{m.gravity || "?"}</span>
                          <span style={{flex:1}}>{m.label || m.headline || ""}</span>
                          {m.activations && m.activations.length > 0 && (
                            <span style={{color:"#8a7a55", fontSize:11}}>
                              ×{m.activations.length}
                            </span>
                          )}
                        </li>
                      ))}
                    </ul>
                  )}
                  {convergence.length > 0 && (
                    <div className="convergence-years">
                      <b style={{color:"#5a4a26", fontSize:12}}>母题汇聚年（≥3 母题同年）：</b>
                      <div style={{marginTop:4}}>
                        {convergence.map((y, i) => (
                          <span key={i} className="y-tag">{typeof y === "object" ? y.year : y}</span>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              </details>

              <details className="virtue-section" open>
                <summary>
                  <span className="vs-pos">位置③</span>
                  <span>汇聚显形 · 母题之间的回响总览</span>
                  <span className="vs-hint">analysis.virtue_narrative.convergence_notes</span>
                </summary>
                <div className="vs-body">
                  {virtueNarrative.convergence_notes && virtueNarrative.convergence_notes.trim() ? (
                    <Markdown source={virtueNarrative.convergence_notes} />
                  ) : (
                    <div className="placeholder">
                      母题汇聚总览尚未写入。{IS_PARTIAL ? "⌛ 流式写作中。" : ""}
                    </div>
                  )}
                </div>
              </details>

              {/* === v9.4 母题侧记 motif_witness（fate master 第三人称累加旁白） === */}
              {Object.keys(motifWitness).length > 0 && (
                <details className="virtue-section" open>
                  <summary>
                    <span className="vs-pos">侧记</span>
                    <span>母题侧记 motif_witness（命理师第三人称累加旁白）</span>
                    <span className="vs-hint">analysis.motif_witness.&lt;anchor&gt;</span>
                  </summary>
                  <div className="vs-body">
                    {Object.keys(motifWitness).map((anchor) => (
                      <div key={anchor} style={{
                        borderLeft: "3px solid #c8b88a",
                        paddingLeft: 10,
                        margin: "8px 0",
                        background: "#fbf6e9",
                        color: "#5a4a26",
                        fontSize: 13,
                      }}>
                        <div style={{fontSize: 11, color: "#8a7a55", marginBottom: 4}}>
                          anchor: <code>{anchor}</code>
                        </div>
                        {motifWitness[anchor] && motifWitness[anchor].trim() ? (
                          <Markdown source={motifWitness[anchor]} />
                        ) : (
                          <div className="placeholder">
                            该 anchor 尚未写入。{IS_PARTIAL ? "⌛ 流式写作中。" : ""}
                          </div>
                        )}
                      </div>
                    ))}
                  </div>
                </details>
              )}

              {/* === v9.3 closing：「我想和你说的话」三段
                       declaration → 「## 我想和你说」
                       love_letter  → 「## 项目的编写者想和你说」
                       free_speech  → 「## 我（大模型）想和你说」
                   不再有「位置④/⑤/⑥」标签 / 硬分隔线 / 提示码，
                   让三段感觉是 LLM 走完八十年后自然落下来的三段告白。 */}
              <div className="virtue-closing">
                {virtueNarrative.declaration && virtueNarrative.declaration.trim() ? (
                  <div className="vc-body"><Markdown source={virtueNarrative.declaration} /></div>
                ) : (
                  <div className="placeholder">
                    「我想和你说」尚未写入。{IS_PARTIAL ? "⌛ 流式写作中。" : ""}
                  </div>
                )}

                {loveOK && (
                  virtueNarrative.love_letter && virtueNarrative.love_letter.trim() ? (
                    <div className="vc-body vc-soft"><Markdown source={virtueNarrative.love_letter} /></div>
                  ) : (
                    <div className="placeholder">
                      「项目的编写者想和你说」尚未写入。{IS_PARTIAL ? "⌛ 流式写作中。" : ""}
                    </div>
                  )
                )}

                {virtueNarrative.free_speech && virtueNarrative.free_speech.trim() ? (
                  <div className="vc-body vc-free"><Markdown source={virtueNarrative.free_speech} /></div>
                ) : (
                  <div className="placeholder">
                    「我（大模型）想和你说」尚未写入。{IS_PARTIAL ? "⌛ 流式写作中。" : ""}
                  </div>
                )}
              </div>
            </>
          );
        })()}

        {HAS_VIRTUE_MOTIFS === false && Object.keys(virtueNarrative).length > 0 && (
          <div className="virtue-section">
            <div className="vs-body">
              <div style={{fontSize:12, color:"#8a7a55", marginBottom:6}}>
                ⚠ 注意：当前未注入 virtue_motifs.json，但 analysis.virtue_narrative 已有内容，
                显示如下（缺少母题骨架对照可能导致写作脱靶）：
              </div>
              {virtueNarrative.opening && <Markdown source={virtueNarrative.opening} />}
              {virtueNarrative.declaration && <Markdown source={virtueNarrative.declaration} />}
              {virtueNarrative.love_letter && <Markdown source={virtueNarrative.love_letter} />}
              {virtueNarrative.free_speech && <Markdown source={virtueNarrative.free_speech} />}
            </div>
          </div>
        )}
      </div>

      {/* === v7.5 时代-民俗志解读层 === */}
      {/* v9.3.1 · 不再静默隐藏: 没传 zeitgeist → 显式 ZeitgeistEmptyExplain */}
      {!(HAS_ZEITGEIST && eraWindows.length > 0) && <ZeitgeistEmptyExplain />}
      {HAS_ZEITGEIST && eraWindows.length > 0 && (
        <div className="card">
          <h2>时代-民俗志解读层（v7.5）</h2>
          <div className="sub">
            把每个 era_window（5-10 年区间）作为一段「时代镶嵌」叙事，
            脚本只给骨架（id/label/span/keywords + 与大运的对齐情况），
            具体「时代底色 / 标志性细节 / 命局节点 / 累计影响 / 证伪点」由 LLM 现场写
          </div>
          <div className="era-banner">
            ⚠ 此层只用于「后事详写」（已发生段的精细化解读），不预测未来；
            对未来段会自动转为「方向性提示」。详见 references/zeitgeist_protocol.md。
          </div>
          <div className="era-list">
            {eraWindows.map((era, i) => {
              const narrative = eraNarratives[era.id];
              const span = era.span || [null, null];
              return (
                <details className="era-item" key={era.id || i} open={i === 0}>
                  <summary>
                    <span className="era-tag">{era.id}</span>
                    <span>{era.label}</span>
                    <span className="era-span">
                      {span[0]}-{span[1]}　·　{era.decade_label || ""}
                    </span>
                    <span className="era-keywords">
                      {(era.keywords || []).slice(0, 5).join(" · ")}
                    </span>
                  </summary>
                  <div className="era-body">
                    <div className="era-meta">
                      <b>骨架：</b>{(era.keywords || []).join(" · ")}
                    </div>
                    {narrative && narrative.trim() ? (
                      <Markdown source={narrative} />
                    ) : (
                      <div className="placeholder">
                        「{era.label}」这一段时代背景的叙事尚未写入。
                        {IS_PARTIAL ? "⌛ 流式写作中。" : ""}
                      </div>
                    )}
                  </div>
                </details>
              );
            })}
          </div>
        </div>
      )}

      {/* === 大运评价 === */}
      <div className="card">
        <h2>大运评价（每 10 年一段）</h2>
        <div className="sub">每个大运段对命主的整体影响评估，点开看详细推论</div>
        <div className="dayun-list">
          {segments.map((seg, i) => {
            const r = dayunReview[seg.label] || {};
            // v7.5: dayun_reviews[label] 是完整 markdown（按 dayun_review_template.md 6 块写法），优先于 r.body
            const fullReview = dayunReviews[seg.label];
            return (
              <details className="dayun-item" key={i} open={i === 0}>
                <summary>
                  <span className="du-tag" style={{background: dayunColor(i)}}>{seg.label}</span>
                  <span className="du-range">{seg.start_age}-{seg.end_age} 岁　{seg.start_year}-{seg.end_year}</span>
                  <span className="du-summary">{r.headline || "—"}</span>
                </summary>
                <div className="du-body">
                  {fullReview && fullReview.trim() ? (
                    <Markdown source={fullReview} />
                  ) : r.body && r.body.trim() ? (
                    <Markdown source={r.body} />
                  ) : (
                    <div className="placeholder">
                      「{seg.label}」大运的整体评价尚未写入。{IS_PARTIAL ? "⌛ 流式写作中。" : ""}
                    </div>
                  )}
                </div>
              </details>
            );
          })}
        </div>
      </div>

      {/* === 关键年份评价 === */}
      <div className="card">
        <h2>关键年份评价（过往 + 未来）</h2>
        <div className="sub">人生中的高峰、低谷、转折年。每条都展开了完整的大白话推论。</div>
        {keyYears.length === 0 ? (
          <div className="placeholder">
            关键年份评价尚未写入。{IS_PARTIAL ? "⌛ 流式写作中，关键高峰 / 低谷 / 转折年会陆续补齐。" : ""}
          </div>
        ) : keyYears.map((k, i) => {
          const pt = pointsByYear[k.year];
          const mpEvents = pt ? (pt.mangpai_events || []) : [];
          const tagLabel = ({peak: "高峰", dip: "低谷", shift: "转折"}[k.kind] || k.kind);
          return (
            <details className="key-year" key={i} open={i < 2}>
              <summary>
                <span className="ky-year">{k.year} · {k.age}岁</span>
                <span>{k.ganzhi} · {k.dayun}</span>
                <span className={"ky-tag "+k.kind}>{tagLabel}</span>
                <span className="ky-headline">{k.headline}</span>
              </summary>
              <div className="ky-body">
                <MangpaiBlock events={mpEvents} />
                {k.body && k.body.trim() ? (
                  <Markdown source={k.body} />
                ) : (
                  <div className="placeholder">（待 LLM 写入推论）</div>
                )}
              </div>
            </details>
          );
        })}
      </div>
    </>
  );
}

ReactDOM.createRoot(document.getElementById("app")).render(
  <ErrorBoundary>
    <App />
  </ErrorBoundary>
);
</script>
{% endraw %}
</body>
</html>
