} = Recharts;

/* === 5 年段趋势线：每 5 年取一段均值，对齐到段中心 === */
function buildSegmentTrend(yearly) {
  const SEG = 5;
  const out = [];
  for (let i = 0; i < yearly.length; i += SEG) {
    const slice = yearly.slice(i, Math.min(i + SEG, yearly.length));
    const ages  = slice.map(p => p.age);
    const center = (ages[0] + ages[ages.length - 1]) / 2;
    const mean = slice.reduce((s, p) => s + p.value, 0) / slice.length;
    out.push({ age: center, value: Math.round(mean * 10) / 10 });
  }
  return out;
}

function buildSeries(curves) {
  // v9.3.1 · resilience guard: curves / curves.points 任一缺失返回空 series，
  // 让 chart 渲染层走 NoChartFallback，不再整页 TypeError。
  const points = Array.isArray(curves && curves.points) ? curves.points : [];
  const main = points.map(p => ({
    age: p.age, year: p.year, dayun: p.dayun,
    spirit:  p.spirit_yearly,
    wealth:  p.wealth_yearly,
    fame:    p.fame_yearly,
    emotion: p.emotion_yearly,
  }));
  const spiritTrend  = buildSegmentTrend(points.map(p => ({age: p.age, value: p.spirit_yearly})));
  const wealthTrend  = buildSegmentTrend(points.map(p => ({age: p.age, value: p.wealth_yearly})));
  const fameTrend    = buildSegmentTrend(points.map(p => ({age: p.age, value: p.fame_yearly})));
  const emotionTrend = buildSegmentTrend(
    points
      .filter(p => p.emotion_yearly != null)
      .map(p => ({age: p.age, value: p.emotion_yearly}))
  );
  // 合并到主数据集（用 age 对齐，趋势数据点用单独字段）
  const trendByAge = {};
  spiritTrend.forEach(p  => { trendByAge[p.age] = trendByAge[p.age] || {}; trendByAge[p.age].spirit_t  = p.value; });
  wealthTrend.forEach(p  => { trendByAge[p.age] = trendByAge[p.age] || {}; trendByAge[p.age].wealth_t  = p.value; });
  fameTrend.forEach(p    => { trendByAge[p.age] = trendByAge[p.age] || {}; trendByAge[p.age].fame_t    = p.value; });
  emotionTrend.forEach(p => { trendByAge[p.age] = trendByAge[p.age] || {}; trendByAge[p.age].emotion_t = p.value; });

  // 把趋势点（可能是非整数年龄）作为单独序列返回，避免 Recharts 数值轴对不齐
  return {
    main,
    trend: { spirit: spiritTrend, wealth: wealthTrend, fame: fameTrend, emotion: emotionTrend },
  };
}

