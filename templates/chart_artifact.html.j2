<!-- v9.3.1 · CDN / 全局错误兜底 (vanilla JS, 不依赖 React/Recharts/marked, 任何一个挂掉都能跑) -->
<script>
(function () {
  var rendered = false;
  function showFatal(title, detail) {
    if (rendered) return;
    rendered = true;
    var app = document.getElementById('app');
    if (!app) return;
