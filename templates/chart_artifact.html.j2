                  <summary>
                    <span className="vs-pos">位置⑤</span>
                    <span>情书（仅 love_letter_eligible 才写）</span>
                    <span className="vs-hint">analysis.virtue_narrative.love_letter</span>
                  </summary>
                  <div className="vs-body">
                    {virtueNarrative.love_letter && virtueNarrative.love_letter.trim() ? (
                      <Markdown source={virtueNarrative.love_letter} />
                    ) : (
                      <div className="placeholder">
                        （此处由 LLM 写一封给命主的情书。
                        条件已成立（love_letter_eligible=true）。
                        {IS_PARTIAL ? "⌛ 流式写作中" : ""}）
                      </div>
                    )}
                  </div>
                </details>
              )}

              <details className="virtue-section" open>
                <summary>
                  <span className="vs-pos">位置⑥</span>
                  <span>LLM 自由话（解读师写完之后想说的话）</span>
                  <span className="vs-hint">analysis.virtue_narrative.free_speech</span>
                </summary>
                <div className="vs-body">
                  {virtueNarrative.free_speech && virtueNarrative.free_speech.trim() ? (
                    <Markdown source={virtueNarrative.free_speech} />
                  ) : (
                    <div className="placeholder">
                      （此处由 LLM 在所有结构化输出之后，写一段不强求结构、不强求长度的自由话。
                      可以是疑问、可以是停顿、可以是把话还给命主。
                      {IS_PARTIAL ? "⌛ 流式写作中" : ""}）
                    </div>
                  )}
                </div>
              </details>
            </>
          );
        })()}

        {HAS_VIRTUE_MOTIFS === false && Object.keys(virtueNarrative).length > 0 && (
          <div className="virtue-section">
            <div className="vs-body">
              <div style={{fontSize:12, color:"#8a7a55", marginBottom:6}}>
                ⚠ 注意：当前未注入 virtue_motifs.json，但 analysis.virtue_narrative 已有内容，
                显示如下（缺少母题骨架对照可能导致写作脱靶）：
              </div>
              {virtueNarrative.opening && <Markdown source={virtueNarrative.opening} />}
              {virtueNarrative.declaration && <Markdown source={virtueNarrative.declaration} />}
              {virtueNarrative.love_letter && <Markdown source={virtueNarrative.love_letter} />}
              {virtueNarrative.free_speech && <Markdown source={virtueNarrative.free_speech} />}
            </div>
          </div>
        )}
      </div>

      {/* === v7.5 时代-民俗志解读层（仅在传入 zeitgeist 时显示） === */}
      {HAS_ZEITGEIST && eraWindows.length > 0 && (
        <div className="card">
          <h2>时代-民俗志解读层（v7.5）</h2>
          <div className="sub">
            把每个 era_window（5-10 年区间）作为一段「时代镶嵌」叙事，
            脚本只给骨架（id/label/span/keywords + 与大运的对齐情况），
            具体「时代底色 / 标志性细节 / 命局节点 / 累计影响 / 证伪点」由 LLM 现场写
          </div>
          <div className="era-banner">
            ⚠ 此层只用于「后事详写」（已发生段的精细化解读），不预测未来；
            对未来段会自动转为「方向性提示」。详见 references/zeitgeist_protocol.md。
          </div>
          <div className="era-list">
            {eraWindows.map((era, i) => {
              const narrative = eraNarratives[era.id];
              const span = era.span || [null, null];
              return (
                <details className="era-item" key={era.id || i} open={i === 0}>
                  <summary>
                    <span className="era-tag">{era.id}</span>
                    <span>{era.label}</span>
                    <span className="era-span">
                      {span[0]}-{span[1]}　·　{era.decade_label || ""}
                    </span>
                    <span className="era-keywords">
                      {(era.keywords || []).slice(0, 5).join(" · ")}
                    </span>
                  </summary>
                  <div className="era-body">
                    <div className="era-meta">
                      <b>骨架：</b>{(era.keywords || []).join(" · ")}
                    </div>
                    {narrative && narrative.trim() ? (
                      <Markdown source={narrative} />
                    ) : (
                      <div className="placeholder">
                        （此处由 LLM 按 references/zeitgeist_protocol.md §3 写入「区间叙事」：
                        ①时代底色（1-2 句不带身份名词的中性概括）　
                        ②标志性细节（民俗志层 6 子层挑 ≥ 3 项 high/mid 置信）　
                        ③命局给的几个具体节点（首选形态 + 备选形态）　
                        ④累计影响（这一段如何沉淀到命主的人生轨迹）　
                        ⑤整段证伪点。
                        key = "{era.id}"。）
                      </div>
                    )}
                  </div>
                </details>
              );
            })}
          </div>
        </div>
      )}

      {/* === 大运评价 === */}
      <div className="card">
        <h2>大运评价（每 10 年一段）</h2>
        <div className="sub">每个大运段对命主的整体影响评估，点开看详细推论</div>
        <div className="dayun-list">
          {segments.map((seg, i) => {
            const r = dayunReview[seg.label] || {};
            // v7.5: dayun_reviews[label] 是完整 markdown（按 dayun_review_template.md 6 块写法），优先于 r.body
            const fullReview = dayunReviews[seg.label];
            return (
              <details className="dayun-item" key={i} open={i === 0}>
                <summary>
                  <span className="du-tag" style={{background: dayunColor(i)}}>{seg.label}</span>
                  <span className="du-range">{seg.start_age}-{seg.end_age} 岁　{seg.start_year}-{seg.end_year}</span>
                  <span className="du-summary">{r.headline || "—"}</span>
                </summary>
                <div className="du-body">
                  {fullReview && fullReview.trim() ? (
                    <Markdown source={fullReview} />
                  ) : r.body && r.body.trim() ? (
                    <Markdown source={r.body} />
                  ) : (
                    <div className="placeholder">
                      （此处由 LLM 写入「{seg.label}」大运的整体评价。
                      key = "{seg.label}"。
                      v7.5 推荐按 references/dayun_review_template.md 的 6 块结构写：
                      ①命理属性　②时代镶嵌（与 era_windows 对齐 · v7.5 重點）　
                      ③三派交叉与盲派应事　④4 维曲线整体倾向　
                      ⑤关键年份概览　⑥核心策略建议。
                      也可写到 ANALYSIS.dayun_reviews["{seg.label}"] 字段（整体 markdown，覆盖此处）。）
                    </div>
                  )}
                </div>
              </details>
            );
          })}
        </div>
      </div>

      {/* === 关键年份评价 === */}
      <div className="card">
        <h2>关键年份评价（过往 + 未来）</h2>
        <div className="sub">人生中的高峰、低谷、转折年。每条都展开了完整的大白话推论。</div>
        {keyYears.length === 0 ? (
          <div className="placeholder">
            （此处由 LLM 按 references/multi_dim_xiangshu_protocol.md §3 写入关键年份。
            数据结构：analysis.key_years = [{`{year, age, ganzhi, dayun, kind, headline, body}`}]
            kind ∈ peak/dip/shift。建议至少覆盖 6-10 个关键年。）
          </div>
        ) : keyYears.map((k, i) => {
          const pt = pointsByYear[k.year];
          const mpEvents = pt ? (pt.mangpai_events || []) : [];
          const tagLabel = ({peak: "高峰", dip: "低谷", shift: "转折"}[k.kind] || k.kind);
          return (
            <details className="key-year" key={i} open={i < 2}>
              <summary>
                <span className="ky-year">{k.year} · {k.age}岁</span>
                <span>{k.ganzhi} · {k.dayun}</span>
                <span className={"ky-tag "+k.kind}>{tagLabel}</span>
                <span className="ky-headline">{k.headline}</span>
              </summary>
              <div className="ky-body">
                <MangpaiBlock events={mpEvents} />
                {k.body && k.body.trim() ? (
                  <Markdown source={k.body} />
                ) : (
                  <div className="placeholder">（待 LLM 写入推论）</div>
                )}
              </div>
            </details>
          );
        })}
      </div>
    </>
  );
}

ReactDOM.createRoot(document.getElementById("app")).render(<App />);
</script>
{% endraw %}
</body>
</html>
